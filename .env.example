# Common
PROJECT_NAME=payflow
TZ=Asia/Seoul

# EC2 test evidence runner (local machine only; never commit a private key)
EC2_HOST=
EC2_SSH_USER=ubuntu
EC2_SSH_KEY_PATH=C:\path\to\ec2-key.pem

# Ports
NGINX_PORT=80
API_GATEWAY_PORT=8080
FRONTEND_PORT=19006
MYSQL_PORT=3306
REDIS_PORT=6379
KAFKA_PORT=9092
FRONTEND_ORIGIN=http://localhost:19006
FRONTEND_API_BASE_URL=http://localhost:8080
FRONTEND_USE_DUMMY_DATA=false
FRONTEND_PARENT_INVITE_CODE=PAYFLOW-PARENT-2024

# MySQL
# [C-3] replace-before-prod: 운영 환경에서는 반드시 강도 높은 패스워드로 교체해야 한다.
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=payflow
MYSQL_PASSWORD=change-me-payflow-password
USER_DB_NAME=payflow_user
WALLET_DB_NAME=payflow_wallet
BANKING_DB_NAME=payflow_banking
TRANSFER_DB_NAME=payflow_transfer
REWARD_DB_NAME=payflow_reward
LEDGER_DB_NAME=payflow_ledger
SETTLEMENT_DB_NAME=payflow_settlement
BANKING_JPA_DDL_AUTO=update
BANKING_FLYWAY_ENABLED=false
BANKING_FLYWAY_BASELINE_ON_MIGRATE=true
BANKING_FLYWAY_BASELINE_VERSION=5
TRANSFER_JPA_DDL_AUTO=update
TRANSFER_FLYWAY_ENABLED=false
TRANSFER_FLYWAY_BASELINE_ON_MIGRATE=true
TRANSFER_FLYWAY_BASELINE_VERSION=3
MYSQL_VOLUME_NAME=payflow_mysql_data
MYSQL_DEV_VOLUME_NAME=payflow_mysql_dev_data
MYSQL_BUFFER_POOL_SIZE=384M
MYSQL_MAX_CONNECTIONS=80

# Redis
REDIS_HOST=redis
REDIS_MAX_MEMORY=96mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru

# Kafka
KAFKA_NODE_ID=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_LOCAL_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_VOLUME_NAME=payflow_kafka_data
KAFKA_DEV_VOLUME_NAME=payflow_kafka_dev_data
KAFKA_HEAP_OPTS=-Xms384m -Xmx768m
KAFKA_LOG_RETENTION_HOURS=24
KAFKA_NUM_PARTITIONS=1

# Security
# [C-3] replace-before-prod: 모든 시크릿은 운영 배포 전 강도 높은 값으로 교체해야 한다.
JWT_SECRET=change-me-at-least-32-bytes-secret-key
JWT_EXPIRATION=86400000
INTERNAL_SERVICE_SECRET=change-me-internal-service-secret
GATEWAY_INTERNAL_SECRET=change-me-gateway-internal-secret
# [H-3] OpenBanking 토큰 암호화 키: 운영 환경에서는 반드시 설정해야 한다. 미설정 시 서비스 시작이 거부된다.
OPENBANKING_TOKEN_ENCRYPTION_SECRET=change-me-openbanking-token-encryption-secret

# JVM
GATEWAY_JAVA_OPTS=-Xms128m -Xmx320m
USER_JAVA_OPTS=-Xms128m -Xmx320m
WALLET_JAVA_OPTS=-Xms128m -Xmx512m
BANKING_JAVA_OPTS=-Xms128m -Xmx512m
TRANSFER_JAVA_OPTS=-Xms128m -Xmx512m
REWARD_JAVA_OPTS=-Xms128m -Xmx384m
LEDGER_JAVA_OPTS=-Xms128m -Xmx320m
SETTLEMENT_JAVA_OPTS=-Xms128m -Xmx320m

# Container memory limits
NGINX_MEM_LIMIT=64m
MYSQL_MEM_LIMIT=512m
REDIS_MEM_LIMIT=128m
KAFKA_MEM_LIMIT=1024m
GATEWAY_MEM_LIMIT=384m
USER_MEM_LIMIT=384m
WALLET_MEM_LIMIT=640m
BANKING_MEM_LIMIT=640m
TRANSFER_MEM_LIMIT=640m
REWARD_MEM_LIMIT=512m
LEDGER_MEM_LIMIT=384m
SETTLEMENT_MEM_LIMIT=384m

# Open Banking
OPENBANKING_MODE=mock
OPENBANKING_BASE_URL=https://testapi.openbanking.or.kr
OPENBANKING_CLIENT_ID=
OPENBANKING_CLIENT_SECRET=
OPENBANKING_CALLBACK_URL=
OPENBANKING_CLIENT_USE_CODE=
OPENBANKING_ACCESS_TOKEN=
OPENBANKING_USER_ACCESS_TOKEN=
OPENBANKING_ORG_ACCESS_TOKEN=
OPENBANKING_CNTR_ACCOUNT_TYPE=N
OPENBANKING_CNTR_ACCOUNT_NUM=
OPENBANKING_WD_PASS_PHRASE=NONE
OPENBANKING_CHARGE_DPS_PRINT_CONTENT=PAYFLOW_CHARGE
OPENBANKING_CHARGE_WD_PRINT_CONTENT=PAYFLOW
OPENBANKING_WITHDRAWAL_WD_PRINT_CONTENT=PAYFLOW_WITHDRAWAL
OPENBANKING_TRANSFER_PURPOSE=TR

# Toss Payments
TOSS_PAYMENTS_MODE=real
TOSS_PAYMENTS_API_BASE_URL=https://api.tosspayments.com
TOSS_PAYMENTS_CLIENT_KEY=test_ck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_PAYMENTS_SECRET_KEY=test_sk_docs_OaPz8L5KdmQXkzRz3y47BMw6
TOSS_PAYMENTS_WEBHOOK_SECRET=
EXPO_PUBLIC_TOSS_CLIENT_KEY=test_ck_docs_Ovk5rk1EwkEbP0W43n07xlzm
